#include <WiFi.h>
#include <PubSubClient.h>

// Configurações da rede Wi-Fi
const char* ssid = "Emerson Sheik";
const char* password = "coritiba";

// Configurações do broker MQTT
const char* mqtt_server = "broker.hivemq.com";
const char* client_id = "iot_ufpr_ventilas750";

// Tópicos MQTT
const char* topic_status_vent1 = "iot/ufpr/c2/vent1/status";
const char* topic_status_vent2 = "iot/ufpr/c2/vent2/status";
const char* topic_rot_vent1 = "iot/ufpr/c2/vent1/rot";
const char* topic_rot_vent2 = "iot/ufpr/c2/vent2/rot";
const char* topic_set_status_vent1 = "iot/ufpr/c2/vent1/set";
const char* topic_set_status_vent2 = "iot/ufpr/c2/vent2/set";
const char* topic_set_rot_vent1 = "iot/ufpr/c2/vent1/set/rpm";
const char* topic_set_rot_vent2 = "iot/ufpr/c2/vent2/set/rpm";

// Variáveis globais
char status_vent1[4] = "OFF";
char status_vent2[4] = "OFF";
float rot_vent1 = 1000;  // Rotação inicial do vent1
float rot_vent2 = 4000;  // Rotação inicial do vent2

WiFiClient espClient;
PubSubClient client(espClient);

// Conectar ao Wi-Fi
void setup_wifi() {
    delay(10);
    Serial.println();
    Serial.print("Conectando-se ao WiFi: ");
    Serial.println(ssid);

    WiFi.begin(ssid, password);

    while (WiFi.status() != WL_CONNECTED) {
        delay(1000);
        Serial.print(".");
    }

    Serial.println("\nWiFi conectado!");
    Serial.print("Endereço IP: ");
    Serial.println(WiFi.localIP());
}

// Publica valores atualizados
void publishUpdates() {
    // Publica status
    client.publish(topic_status_vent1, status_vent1);
    client.publish(topic_status_vent2, status_vent2);

    // Publica rotações
    char buffer[10];
    dtostrf(rot_vent1, 0, 2, buffer);
    client.publish(topic_rot_vent1, buffer);
    dtostrf(rot_vent2, 0, 2, buffer);
    client.publish(topic_rot_vent2, buffer);

    // Log
    Serial.println("Atualizações publicadas:");
    Serial.print("Status Vent1: ");
    Serial.println(status_vent1);
    Serial.print("Status Vent2: ");
    Serial.println(status_vent2);
    Serial.print("Rotação Vent1: ");
    Serial.println(rot_vent1);
    Serial.print("Rotação Vent2: ");
    Serial.println(rot_vent2);
}

// Callback para mensagens recebidas
void callback(char* topic, byte* payload, unsigned int length) {
    char message[100];
    strncpy(message, (char*)payload, length);
    message[length] = '\0';  // Adiciona o terminador nulo

    Serial.print("Mensagem recebida no tópico [");
    Serial.print(topic);
    Serial.print("]: ");
    Serial.println(message);

    bool updated = false;  // Flag para verificar se houve atualização
  //strcmp compara valores
    if (strcmp(topic, topic_set_status_vent1) == 0) {
        if (strcmp(status_vent1, message) != 0) {
            strcpy(status_vent1, message);
            updated = true;
        }
    } else if (strcmp(topic, topic_set_status_vent2) == 0) {
        if (strcmp(status_vent2, message) != 0) {
            strcpy(status_vent2, message);
            updated = true;
        }
    } else if (strcmp(topic, topic_set_rot_vent1) == 0) {
        float new_rot = atof(message);
        if (rot_vent1 != new_rot) {
            rot_vent1 = new_rot;
            updated = true;
        }
    } else if (strcmp(topic, topic_set_rot_vent2) == 0) {
        float new_rot = atof(message);
        if (rot_vent2 != new_rot) {
            rot_vent2 = new_rot;
            updated = true;
        }
    }

    // Publica as atualizações imediatamente se houve alterações
    if (updated) {
        publishUpdates();
    }
}

// Reconectar ao broker MQTT
void reconnect() {
    while (!client.connected()) {
        Serial.print("Conectando-se ao broker MQTT...");
        if (client.connect(client_id)) {
            Serial.println("Conectado!");

            // Inscrever-se nos tópicos
            client.subscribe(topic_set_status_vent1);
            client.subscribe(topic_set_status_vent2);
            client.subscribe(topic_set_rot_vent1);
            client.subscribe(topic_set_rot_vent2);

            Serial.println("Inscrito nos tópicos.");
        } else {
            Serial.print("Falha, rc=");
            Serial.print(client.state());
            Serial.println(" Tentando novamente em 5 segundos...");
            delay(5000);
        }
    }
}

void setup() {
    Serial.begin(115200);
    setup_wifi();

    client.setServer(mqtt_server, 1883);
    client.setCallback(callback);
}

void loop() {
    if (!client.connected()) {
        reconnect();
    }
    client.loop();
}